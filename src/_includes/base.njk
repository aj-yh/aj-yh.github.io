<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{ title }}</title>
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body class="min-h-screen bg-white text-gray-900">
    <header class="px-6 py-4 border-b border-gray-200">
      <nav class="max-w-4xl mx-auto flex items-center justify-between">
        <a href="/" class="font-semibold text-lg">Portfolio</a>
      </nav>
    </header>

    <main class="max-w-4xl mx-auto px-6 py-12">
      {{ content | safe }}
    </main>

    <footer class="mt-auto px-6 py-4 border-t border-gray-200 text-center text-sm text-gray-500">
      &copy; {{ year }} Alexander Hayashi
    </footer>
  </body>
</html>
