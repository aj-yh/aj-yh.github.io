<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{ title }}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body class="min-h-screen bg-[#151515] text-white" style="font-family: 'Space Mono', monospace;">
    <header class="p-4">
      <a href="/" class="inline-block border border-[#444] px-4 py-2 text-white text-base leading-normal">
        Alex Hayashi
      </a>
    </header>

    <main>
      {{ content | safe }}
    </main>

    <footer class="px-4 py-6 text-center text-sm text-[#afafaf]">
      &copy; {{ year }} Alexander Hayashi
    </footer>
  </body>
</html>
