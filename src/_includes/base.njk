<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{ title }}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300..700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body class="min-h-screen bg-[#151515] text-white" style="font-family: 'Space Grotesk', sans-serif;">
    <header class="p-4">
      <a href="/" class="inline-block border border-[#444] px-4 py-2 text-white text-base leading-normal">
        Alex Hayashi
      </a>
    </header>

    <main>
      {{ content | safe }}
    </main>

    {# <footer class="px-4 py-6 text-center text-sm text-[#afafaf]">
      &copy; {{ year }} Alexander Hayashi
    </footer> #}

    <div id="lightbox" class="fixed inset-0 bg-black/90 z-50 flex-col items-center justify-center p-8 gap-4 cursor-zoom-out hidden" role="dialog" aria-modal="true" aria-label="Image viewer">
      <button id="lightbox-close" class="absolute top-4 right-4 text-white text-2xl leading-none cursor-pointer" aria-label="Close">✕</button>
      <img id="lightbox-img" src="" alt="" class="max-w-full max-h-[85vh] object-contain cursor-default" />
      <p id="lightbox-caption" class="text-sm text-[#afafaf] text-center"></p>
    </div>

    <script>
      (function () {
        var lightbox = document.getElementById('lightbox');
        var lightboxImg = document.getElementById('lightbox-img');
        var lightboxCaption = document.getElementById('lightbox-caption');

        function open(img) {
          lightboxImg.src = img.src;
          lightboxImg.alt = img.alt;
          var caption = img.dataset.caption || '';
          lightboxCaption.textContent = caption;
          lightboxCaption.hidden = !caption;
          lightbox.classList.remove('hidden');
          lightbox.classList.add('flex');
          document.body.style.overflow = 'hidden';
        }

        function close() {
          lightbox.classList.add('hidden');
          lightbox.classList.remove('flex');
          lightboxImg.src = '';
          document.body.style.overflow = '';
        }

        document.addEventListener('click', function (e) {
          var img = e.target.closest('[data-lightbox]');
          if (img) open(img);
        });

        document.getElementById('lightbox-close').addEventListener('click', close);

        lightbox.addEventListener('click', function (e) {
          if (e.target === lightbox) close();
        });

        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape' && lightbox.classList.contains('flex')) close();
        });
      })();
    </script>
  </body>
</html>
